# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=Mohak@12
DB_NAME=student_helper
# Optional secure connection settings for MySQL:
# DB_SSL_DISABLED=False
# DB_AUTH_PLUGIN=mysql_native_password
# DB_SSL_CA=/path/to/ca.pem

# Flask Configuration
FLASK_DEBUG=0
FLASK_ENV=development

# CORS Configuration (FIX #1: Restricted Origins)
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:8000,http://localhost:3000,http://127.0.0.1:5501

# FEATURE #2: JWT Configuration
# Change this to a strong secret key in production!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Security & Best Practices:
# 1. Always set DB_PASSWORD via environment variable (.env file)
# 2. Never commit .env file to version control (add to .gitignore) ✅ Done
# 3. In production, use strong database passwords (20+ chars)
# 4. Use a strong JWT_SECRET (32+ chars, cryptographically random)
# 5. Update CORS_ORIGINS for your deployed domain
# 6. Set FLASK_DEBUG=0 in production

# FEATURE #1: Password Hashing
# Passwords are now hashed with bcrypt (12 rounds)
# No configuration needed - works automatically

# FEATURE #3: Rate Limiting
# Applied to vulnerable endpoints:
# - /register: 5 requests per minute per IP
# - /login: 5 requests per minute per IP
# - /post_request: 20 requests per minute per IP
# - /post_answer: 30 requests per minute per IP
# - /accept_answer: 30 requests per minute per IP
# - /create_post: 20 requests per minute per IP
# - /accept_post: 30 requests per minute per IP
# - /purge_user: 2 requests per minute per IP (very restrictive for destructive operation)

