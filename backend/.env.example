# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=student_helper

# Flask Configuration
FLASK_DEBUG=0
FLASK_ENV=development

# CORS Configuration (FIX #1: Restricted Origins)
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:8000,http://localhost:3000,http://127.0.0.1:8000

# Important Security Notes:
# 1. Always set DB_PASSWORD via environment variable (.env file)
# 2. Never commit .env file to version control (add to .gitignore)
# 3. In production, use strong database passwords
# 4. Update CORS_ORIGINS for your deployed domain
